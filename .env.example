# Copy this file to `.env.local` for local development.
# Values here are examples only. Do not commit real credentials.

# -----------------------------
# Application runtime
# -----------------------------
APP_BASE_URL=http://127.0.0.1:3000
APP_TIMEZONE=Europe/London
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SESSION_TTL_S=1800
SESSION_MAX_STATES=1000

# -----------------------------
# Database backend
# -----------------------------
# Use `sqlite` for the lightweight local/demo path.
# Use `mysql` only when running the persistent DB-backed path.
DB_BACKEND=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=fall_app
DB_PASS=strong_password_here
DB_NAME=elder_fall_monitor
SQLITE_PATH=applications/backend/cloud_demo.sqlite3

# -----------------------------
# Safe Guard notification system
# -----------------------------
SAFE_GUARD_ENABLED=1
SAFE_GUARD_SQLITE_PATH=applications/backend/safe_guard_notifications.sqlite3
EVENT_CLIPS_DIR=applications/backend/event_clips
SAFE_GUARD_WORKER_QUEUE_SIZE=256
SAFE_GUARD_WORKER_POLL_INTERVAL_S=0.25
SAFE_GUARD_RETRY_COUNT=2
SAFE_GUARD_HTTP_TIMEOUT_S=8.0

# Threshold-aware notification tiering
HIGH_CONF_MARGIN=0.08
LOW_UNCERTAINTY_THRESHOLD=0.05
HIGH_UNCERTAINTY_THRESHOLD=0.15
ALERT_COOLDOWN_SECONDS=60

# -----------------------------
# Telegram
# -----------------------------
TELEGRAM_BOT_TOKEN=
CAREGIVER_TELEGRAM_CHAT_ID=
TELEGRAM_API_BASE=https://api.telegram.org

# -----------------------------
# Twilio
# -----------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
CAREGIVER_PHONE=

# -----------------------------
# Resend / Email
# -----------------------------
RESEND_API_KEY=
EMAIL_FROM=
CAREGIVER_EMAIL=

# -----------------------------
# AI event analysis email section
# -----------------------------
AI_REPORTS_ENABLED=1
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_TIMEOUT_S=12

# -----------------------------
# Notes
# -----------------------------
# - Telegram / Twilio / Resend / AI provider values are secret-bearing config.
# - Store production secrets only in deployment environment variables.
# - For the supervisor/reviewer path, only APP_BASE_URL, DB_BACKEND, SQLITE_PATH,
#   and optionally Telegram/Gemini settings are typically needed.
