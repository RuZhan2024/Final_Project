# -----------------------------
# Core server / DB
# -----------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=fall_app
DB_PASS=strong_password_here
DB_NAME=elder_fall_monitor

# -----------------------------
# Safe Guard notification system
# -----------------------------
SAFE_GUARD_ENABLED=1
SAFE_GUARD_SQLITE_PATH=server/safe_guard_notifications.sqlite3
SAFE_GUARD_WORKER_QUEUE_SIZE=256
SAFE_GUARD_WORKER_POLL_INTERVAL_S=0.25
SAFE_GUARD_RETRY_COUNT=2
SAFE_GUARD_HTTP_TIMEOUT_S=8.0

# Threshold-aware notification tiering
HIGH_CONF_MARGIN=0.08
LOW_UNCERTAINTY_THRESHOLD=0.05
HIGH_UNCERTAINTY_THRESHOLD=0.15
ALERT_COOLDOWN_SECONDS=60

# -----------------------------
# Twilio
# -----------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
CAREGIVER_PHONE=

# -----------------------------
# SMTP / Email
# -----------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
CAREGIVER_EMAIL=

# -----------------------------
# App links
# -----------------------------
APP_BASE_URL=http://127.0.0.1:3000
