# -----------------------------------------
# Aliases / convenience targets
# -----------------------------------------
train: train-le2i
	@echo "Done (train-le2i)."

train-gcn: train-gcn-le2i
	@echo "Done (train-gcn-le2i)."

fit-ops: fit-ops-le2i
	@echo "Done (fit-ops-le2i)."

fit-ops-gcn: fit-ops-gcn-le2i
	@echo "Done (fit-ops-gcn-le2i)."

eval-urfd: eval-le2i-on-urfd
	@echo "Done (eval-le2i-on-urfd)."

eval-urfd-gcn: eval-le2i-gcn-on-urfd
	@echo "Done (eval-le2i-gcn-on-urfd)."

plot: plot-urfd-cross
	@echo "Done (plot-urfd-cross)."

pipeline: pipeline-le2i
	@echo "Done (pipeline-le2i)."

# -----------------------------------------
# Pipelines
# -----------------------------------------
# ---- per-dataset pipelines (TCN) ----
pipeline-le2i: extract-le2i labels-le2i splits-le2i $(PREPROCESS_STEP_LE2I) windows-le2i le2i-unlabeled-list windows-le2i-unlabeled check-le2i \
              train-le2i fit-ops-le2i eval-le2i plot-le2i score-unlabeled-le2i
	@echo "LE2I pipeline complete (TCN)."

pipeline-urfd: extract-urfd labels-urfd splits-urfd $(PREPROCESS_STEP_URFD) windows-urfd check-urfd train-urfd fit-ops-urfd
	@echo "URFD pipeline complete (TCN)."

pipeline-caucafall: extract-caucafall labels-caucafall splits-caucafall $(PREPROCESS_STEP_CAUC) windows-caucafall check-caucafall \
                   train-caucafall fit-ops-caucafall eval-caucafall plot-caucafall
	@echo "CAUCAFall pipeline complete (TCN)."

pipeline-muvim: extract-muvim labels-muvim splits-muvim $(PREPROCESS_STEP_MUVIM) windows-muvim check-muvim \
              train-muvim fit-ops-muvim eval-muvim plot-muvim
	@echo "MUVIM pipeline complete (TCN)."

pipeline-all: pipeline-le2i pipeline-urfd pipeline-caucafall pipeline-muvim
	@echo "All datasets complete (TCN)."

pipeline-cross: eval-le2i-on-urfd plot-urfd-cross eval-caucafall-on-urfd plot-caucafall-on-urfd
	@echo "Cross-dataset evaluations complete (TCN)."

# ---- per-dataset pipelines (GCN) ----
pipeline-le2i-gcn: extract-le2i labels-le2i splits-le2i $(PREPROCESS_STEP_LE2I) windows-le2i le2i-unlabeled-list windows-le2i-unlabeled check-le2i \
                  train-gcn-le2i fit-ops-gcn-le2i eval-le2i-gcn plot-le2i-gcn score-unlabeled-le2i-gcn
	@echo "LE2I pipeline complete (GCN)."

pipeline-urfd-gcn: extract-urfd labels-urfd splits-urfd $(PREPROCESS_STEP_URFD) windows-urfd check-urfd \
                  train-gcn-urfd fit-ops-gcn-urfd
	@echo "URFD pipeline complete (GCN)."

pipeline-caucafall-gcn: extract-caucafall labels-caucafall splits-caucafall $(PREPROCESS_STEP_CAUC) windows-caucafall check-caucafall \
                       train-gcn-caucafall fit-ops-gcn-caucafall eval-caucafall-gcn plot-caucafall-gcn
	@echo "CAUCAFall pipeline complete (GCN)."

pipeline-muvim-gcn: extract-muvim labels-muvim splits-muvim $(PREPROCESS_STEP_MUVIM) windows-muvim check-muvim \
                   train-gcn-muvim fit-ops-gcn-muvim eval-muvim-gcn plot-muvim-gcn
	@echo "MUVIM pipeline complete (GCN)."

pipeline-all-gcn: pipeline-le2i-gcn pipeline-urfd-gcn pipeline-caucafall-gcn pipeline-muvim-gcn
	@echo "All datasets complete (GCN)."

pipeline-cross-gcn: eval-le2i-gcn-on-urfd plot-urfd-cross-gcn eval-caucafall-gcn-on-urfd plot-caucafall-on-urfd-gcn
	@echo "Cross-dataset evaluations complete (GCN)."

# ---- GCN pipelines (reuse existing extracted poses / labels / splits / windows) ----
pipeline-le2i-gcn-fast: train-gcn-le2i fit-ops-gcn-le2i eval-le2i-gcn plot-le2i-gcn score-unlabeled-le2i-gcn
	@echo "LE2I GCN pipeline complete (FAST)."

pipeline-urfd-gcn-fast: train-gcn-urfd fit-ops-gcn-urfd eval-urfd-gcn plot-urfd-gcn
	@echo "URFD GCN pipeline complete (FAST)."

pipeline-caucafall-gcn-fast: train-gcn-caucafall fit-ops-gcn-caucafall eval-caucafall-gcn plot-caucafall-gcn
	@echo "CAUCAFall GCN pipeline complete (FAST)."

pipeline-muvim-gcn-fast: train-gcn-muvim fit-ops-gcn-muvim eval-muvim-gcn plot-muvim-gcn
	@echo "MUVIM GCN pipeline complete (FAST)."

pipeline-all-gcn-fast: pipeline-le2i-gcn-fast pipeline-urfd-gcn-fast pipeline-caucafall-gcn-fast pipeline-muvim-gcn-fast
	@echo "All datasets complete (GCN FAST)."

pipeline-cross-gcn-fast: eval-le2i-gcn-on-urfd plot-urfd-cross-gcn eval-caucafall-gcn-on-urfd plot-caucafall-on-urfd-gcn
	@echo "Cross-dataset evaluations complete (GCN FAST)."

