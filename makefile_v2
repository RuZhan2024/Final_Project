# -----------------------------------------
# Makefile (task runner) — Fall Detection v2
# -----------------------------------------
SHELL := /bin/bash
.DEFAULT_GOAL := help

# Python + venv
PY=python
VENV=source .venv/bin/activate

# Windowing knobs (override: make WIN_W=64 WIN_S=16 train)
WIN_W ?= 48
WIN_S ?= 12

# Split knobs (keep simple to avoid Make parsing issues)
SPLIT_SEED ?= 33724876
TRAIN_FRAC ?= 0.80
VAL_FRAC   ?= 0.10
TEST_FRAC  ?= 0.10

# Dataset FPS (used for velocity features + FA/24h style calculations)
FPS_LE2I ?= 25
FPS_CAUC ?= 23
FPS_URFD ?= 30
FPS_MUVIM ?= 30

# -----------------------------------------
# Preprocess (pose NPZ cleaning) — optional
# -----------------------------------------
# Toggle: if 1, windowing uses pose_npz_clean instead of pose_npz
USE_PREPROCESS ?= 0

# Script location (override if you put it elsewhere)
PREPROCESS_SCRIPT ?= preprocess_pose_npz.py

# Preprocess knobs (override: make preprocess-le2i CONF_THR=0.25 SMOOTH_K=7)
CONF_THR   ?= 0.2
SMOOTH_K   ?= 5
MAX_GAP    ?= 4
NORM_MODE  ?= torso   # none | torso | shoulder

# Pose dirs (raw + cleaned)
POSE_RAW_LE2I   := data/interim/le2i/pose_npz
POSE_CLEAN_LE2I := data/interim/le2i/pose_npz_clean

POSE_RAW_URFD   := data/interim/urfd/pose_npz
POSE_CLEAN_URFD := data/interim/urfd/pose_npz_clean

POSE_RAW_CAUC   := data/interim/caucafall/pose_npz
POSE_CLEAN_CAUC := data/interim/caucafall/pose_npz_clean

POSE_RAW_MUVIM   := data/interim/muvim/pose_npz
POSE_CLEAN_MUVIM := data/interim/muvim/pose_npz_clean

# Which pose dir windowing should read from (auto-switch with USE_PREPROCESS)
NPZ_DIR_LE2I := $(POSE_RAW_LE2I)
NPZ_DIR_URFD := $(POSE_RAW_URFD)
NPZ_DIR_CAUC := $(POSE_RAW_CAUC)
NPZ_DIR_MUVIM := $(POSE_RAW_MUVIM)

ifeq ($(USE_PREPROCESS),1)
NPZ_DIR_LE2I := $(POSE_CLEAN_LE2I)
NPZ_DIR_URFD := $(POSE_CLEAN_URFD)
NPZ_DIR_CAUC := $(POSE_CLEAN_CAUC)
NPZ_DIR_MUVIM := $(POSE_CLEAN_MUVIM)
endif

# Optional: pipeline inserts preprocess step only when enabled
PREPROCESS_STEP_LE2I :=
PREPROCESS_STEP_URFD :=
PREPROCESS_STEP_CAUC :=
PREPROCESS_STEP_MUVIM :=

ifeq ($(USE_PREPROCESS),1)
PREPROCESS_STEP_LE2I := preprocess-le2i
PREPROCESS_STEP_URFD := preprocess-urfd
PREPROCESS_STEP_CAUC := preprocess-caucafall
PREPROCESS_STEP_MUVIM := preprocess-muvim
endif

# Derived paths
WIN_DIR_LE2I      := data/processed/le2i/windows_W$(WIN_W)_S$(WIN_S)
WIN_DIR_URFD      := data/processed/urfd/windows_W$(WIN_W)_S$(WIN_S)
WIN_DIR_CAUC      := data/processed/caucafall/windows_W$(WIN_W)_S$(WIN_S)
WIN_DIR_MUVIM     := data/processed/muvim/windows_W$(WIN_W)_S$(WIN_S)

# TCN checkpoints
CKPT_LE2I         := outputs/le2i_tcn_W$(WIN_W)S$(WIN_S)/best.pt
CKPT_URFD         := outputs/urfd_tcn_W$(WIN_W)S$(WIN_S)/best.pt
CKPT_CAUC         := outputs/caucafall_tcn_W$(WIN_W)S$(WIN_S)/best.pt
CKPT_MUVIM        := outputs/muvim_tcn_W$(WIN_W)S$(WIN_S)/best.pt

# GCN checkpoints
CKPT_LE2I_GCN     := outputs/le2i_gcn_W$(WIN_W)S$(WIN_S)/best.pt
CKPT_URFD_GCN     := outputs/urfd_gcn_W$(WIN_W)S$(WIN_S)/best.pt
CKPT_CAUC_GCN     := outputs/caucafall_gcn_W$(WIN_W)S$(WIN_S)/best.pt
CKPT_MUVIM_GCN    := outputs/muvim_gcn_W$(WIN_W)S$(WIN_S)/best.pt

# OP configs (TCN)
OPS_LE2I          := configs/ops_le2i.yaml
OPS_URFD          := configs/ops_urfd.yaml
OPS_CAUC          := configs/ops_caucafall.yaml
OPS_MUVIM         := configs/ops_muvim.yaml

# OP configs (GCN)
OPS_LE2I_GCN      := configs/ops_le2i_gcn.yaml
OPS_URFD_GCN      := configs/ops_urfd_gcn.yaml
OPS_CAUC_GCN      := configs/ops_caucafall_gcn.yaml
OPS_MUVIM_GCN     := configs/ops_muvim_gcn.yaml

.PHONY: help install \
        extract-le2i extract-urfd extract-caucafall extract-muvim \
        preprocess-le2i preprocess-urfd preprocess-caucafall preprocess-muvim preprocess-all \
        labels-le2i le2i-unlabeled-list labels-urfd labels-caucafall labels-muvim \
        splits-le2i splits-urfd splits-caucafall splits-muvim splits-all \
        windows-le2i windows-le2i-unlabeled windows-urfd windows-caucafall windows-muvim \
        check-le2i check-urfd check-caucafall check-muvim \
        train train-le2i train-urfd train-caucafall train-muvim \
        train-gcn train-gcn-le2i train-gcn-urfd train-gcn-caucafall train-gcn-muvim train-gcn-all \
        fit-ops fit-ops-le2i fit-ops-urfd fit-ops-caucafall fit-ops-muvim \
        fit-ops-gcn fit-ops-gcn-le2i fit-ops-gcn-urfd fit-ops-gcn-caucafall fit-ops-gcn-muvim \
        eval-le2i eval-urfd eval-le2i-on-urfd eval-caucafall eval-caucafall-on-urfd eval-muvim \
        eval-le2i-gcn eval-urfd-gcn eval-le2i-gcn-on-urfd eval-caucafall-gcn eval-caucafall-gcn-on-urfd eval-muvim-gcn \
        plot plot-urfd-cross plot-le2i plot-caucafall plot-caucafall-on-urfd plot-muvim \
        plot-le2i-gcn plot-urfd-gcn plot-caucafall-gcn plot-muvim-gcn plot-urfd-cross-gcn plot-caucafall-on-urfd-gcn \
        pipeline pipeline-le2i pipeline-urfd pipeline-caucafall pipeline-muvim pipeline-all pipeline-cross \
        pipeline-le2i-gcn pipeline-urfd-gcn pipeline-caucafall-gcn pipeline-muvim-gcn pipeline-all-gcn pipeline-cross-gcn \
        pipeline-le2i-gcn-fast pipeline-urfd-gcn-fast pipeline-caucafall-gcn-fast pipeline-muvim-gcn-fast \
        pipeline-all-gcn-fast pipeline-cross-gcn-fast \
        score-unlabeled-le2i score-unlabeled-le2i-gcn \
        clean clean-le2i clean-urfd clean-caucafall clean-muvim clean-windows clean-outputs

help:
	@echo "Targets:"
	@echo "  make install                 # create venv, lock & install deps"
	@echo "  make extract-<ds>            # extract pose/NPZ for le2i|urfd|caucafall|muvim"
	@echo "  make preprocess-<ds>         # clean/smooth/normalise pose NPZs (optional)"
	@echo "  make preprocess-all          # preprocess all datasets"
	@echo "  make USE_PREPROCESS=1 windows-le2i    # window using pose_npz_clean"
	@echo "  make labels-<ds>             # build labels for le2i/urfd/caucafall/muvim"
	@echo "  make splits-<ds>             # stratified splits"
	@echo "  make windows-<ds>            # windowify datasets"
	@echo "  make check-<ds>              # sanity-check window counts/labels"
	@echo "  make train-le2i|train-urfd|train-caucafall|train-muvim        # train TCN per dataset"
	@echo "  make train-gcn-le2i|train-gcn-urfd|train-gcn-caucafall|train-gcn-muvim  # train GCN per dataset"
	@echo "  make train                   # alias for train-le2i (baseline TCN)"
	@echo "  make train-gcn               # alias for train-gcn-le2i (baseline GCN)"
	@echo "  make fit-ops-le2i            # fit OP1/2/3 on LE2I val (TCN)"
	@echo "  make fit-ops-gcn-le2i        # fit OP1/2/3 on LE2I val (GCN)"
	@echo "  make eval-le2i               # LE2I in-domain (TCN)"
	@echo "  make eval-le2i-gcn           # LE2I in-domain (GCN)"
	@echo "  make eval-urfd               # alias: LE2I TCN model on URFD (cross)"
	@echo "  make eval-urfd-gcn           # alias: LE2I GCN model on URFD (cross)"
	@echo "  make plot-urfd-cross         # FA/24h vs recall plot for LE2I→URFD (TCN)"
	@echo "  make plot-urfd-cross-gcn     # FA/24h vs recall plot for LE2I→URFD (GCN)"
	@echo "  make pipeline                # end-to-end LE2I pipeline (TCN)"
	@echo "  make pipeline-le2i-gcn       # end-to-end LE2I pipeline (GCN)"
	@echo "  make pipeline-le2i-gcn-fast  # reuse existing windows; train/eval only (GCN)"
	@echo "  make clean*                  # remove intermediates/outputs"

# -----------------------------------------
# Setup
# -----------------------------------------
install:
	@[ -d .venv ] || python3 -m venv .venv
	$(VENV) && $(PY) -m pip install --upgrade "pip==24.2" "pip-tools==7.4.1" setuptools wheel && \
	pip-compile --resolver=backtracking requirements.in && \
	pip-sync requirements.txt

# -----------------------------------------
# Extract
# -----------------------------------------
extract-le2i:
	$(VENV) && $(PY) pose/extract_2d.py \
	  --videos_glob 'data/raw/LE2i/**/videos/*.avi' 'data/raw/LE2i/**/*.avi' \
	               'data/raw/LE2i/**/videos/*.mp4' 'data/raw/LE2i/**/*.mp4' \
	  --out_dir 'data/interim/le2i/pose_npz' \
	  --fps_default $(FPS_LE2I) \
	  --skip_existing || true

extract-urfd:
	$(VENV) && $(PY) pose/extract_2d_from_images.py \
	  --images_glob 'data/raw/UR_Fall/adl/*/*.png' 'data/raw/UR_Fall/fall/*/*.png' \
	  --sequence_id_depth 1 \
	  --out_dir data/interim/urfd/pose_npz \
	  --dataset urfd \
	  --fps $(FPS_URFD)

extract-caucafall:
	$(VENV) && $(PY) pose/extract_2d_from_images.py \
	  --images_glob 'data/raw/CAUCAFall/CAUCAFall/*/*/*.png' \
	  --sequence_id_depth 2 \
	  --out_dir data/interim/caucafall/pose_npz \
	  --dataset caucafall \
	  --fps $(FPS_CAUC)

# Optional: requires your MUVIM frame export / layout
extract-muvim:
	$(VENV) && $(PY) pose/extract_2d_from_images.py \
	  --images_glob 'data/raw/MUVIM/ZED_RGB/ADL/*/*.png' \
	                'data/raw/MUVIM/ZED_RGB/Fall/*/*.png' \
	  --sequence_id_depth 1 \
	  --out_dir data/interim/muvim/pose_npz \
	  --dataset muvim \
	  --fps $(FPS_MUVIM)

# -----------------------------------------
# Preprocess (pose_npz -> pose_npz_clean)
# -----------------------------------------
preprocess-le2i:
	$(VENV) && $(PY) $(PREPROCESS_SCRIPT) \
	  --in_dir  $(POSE_RAW_LE2I) \
	  --out_dir $(POSE_CLEAN_LE2I) \
	  --recursive \
	  --conf_thr $(CONF_THR) \
	  --smooth_k $(SMOOTH_K) \
	  --max_gap $(MAX_GAP) \
	  --normalize $(NORM_MODE)

preprocess-urfd:
	$(VENV) && $(PY) $(PREPROCESS_SCRIPT) \
	  --in_dir  $(POSE_RAW_URFD) \
	  --out_dir $(POSE_CLEAN_URFD) \
	  --recursive \
	  --conf_thr $(CONF_THR) \
	  --smooth_k $(SMOOTH_K) \
	  --max_gap $(MAX_GAP) \
	  --normalize $(NORM_MODE)

preprocess-caucafall:
	$(VENV) && $(PY) $(PREPROCESS_SCRIPT) \
	  --in_dir  $(POSE_RAW_CAUC) \
	  --out_dir $(POSE_CLEAN_CAUC) \
	  --recursive \
	  --conf_thr $(CONF_THR) \
	  --smooth_k $(SMOOTH_K) \
	  --max_gap $(MAX_GAP) \
	  --normalize $(NORM_MODE)

preprocess-muvim:
	$(VENV) && $(PY) $(PREPROCESS_SCRIPT) \
	  --in_dir  $(POSE_RAW_MUVIM) \
	  --out_dir $(POSE_CLEAN_MUVIM) \
	  --recursive \
	  --conf_thr $(CONF_THR) \
	  --smooth_k $(SMOOTH_K) \
	  --max_gap $(MAX_GAP) \
	  --normalize $(NORM_MODE)

preprocess-all: preprocess-le2i preprocess-urfd preprocess-caucafall preprocess-muvim
	@echo "Preprocess complete for all datasets."

# -----------------------------------------
# Labels
# -----------------------------------------
labels-le2i:
	@mkdir -p configs/labels
	$(VENV) && $(PY) labels/make_le2i_labels.py \
	  --raw_root data/raw/LE2i \
	  --npz_dir  data/interim/le2i/pose_npz \
	  --out_labels configs/labels/le2i.json \
	  --out_spans  configs/labels/le2i_spans.json

le2i-unlabeled-list:
	@mkdir -p configs/splits
	$(VENV) && $(PY) labels/make_unlabeled_test_list.py \
	  --npz_dir $(NPZ_DIR_LE2I) \
	  --out configs/splits/le2i_test_unlabeled.txt \
	  --scenes Office "Lecture room"

labels-urfd:
	@mkdir -p configs/labels
	$(VENV) && $(PY) labels/make_urfd_labels.py \
	  --npz_dir data/interim/urfd/pose_npz \
	  --out configs/labels/urfd_auto.json

labels-caucafall:
	@mkdir -p configs/labels
	$(VENV) && $(PY) labels/make_caucafall_labels.py \
	  --npz_dir data/interim/caucafall/pose_npz \
	  --out configs/labels/caucafall_auto.json

# If you have a MUVIM label generator, point it here.
labels-muvim:
	@mkdir -p configs/labels
	$(VENV) && $(PY) labels/make_muvim_labels.py \
	  --npz_dir data/interim/muvim/pose_npz \
	  --out configs/labels/muvim_auto.json

# -----------------------------------------
# Splits
# -----------------------------------------
splits-le2i:
	@mkdir -p configs/splits
	$(VENV) && $(PY) split/make_splits.py \
	  --labels_json configs/labels/le2i.json \
	  --out_dir configs/splits \
	  --train $(TRAIN_FRAC) --val $(VAL_FRAC) --test $(TEST_FRAC) --seed $(SPLIT_SEED)

splits-urfd:
	@mkdir -p configs/splits
	$(VENV) && $(PY) split/make_splits.py \
	  --labels_json configs/labels/urfd_auto.json \
	  --out_dir configs/splits \
	  --train $(TRAIN_FRAC) --val $(VAL_FRAC) --test $(TEST_FRAC) --seed $(SPLIT_SEED) \
	  --prefix urfd

splits-caucafall:
	@mkdir -p configs/splits
	$(VENV) && $(PY) split/make_splits.py \
	  --labels_json configs/labels/caucafall_auto.json \
	  --out_dir configs/splits \
	  --train $(TRAIN_FRAC) --val $(VAL_FRAC) --test $(TEST_FRAC) --seed $(SPLIT_SEED) \
	  --prefix caucafall

splits-muvim:
	@mkdir -p configs/splits
	$(VENV) && $(PY) split/make_splits.py \
	  --labels_json configs/labels/muvim_auto.json \
	  --out_dir configs/splits \
	  --train $(TRAIN_FRAC) --val $(VAL_FRAC) --test $(TEST_FRAC) --seed $(SPLIT_SEED) \
	  --prefix muvim

splits-all: splits-le2i splits-urfd splits-caucafall splits-muvim
	@echo "Splits created for all datasets."

# -----------------------------------------
# Windowing
# -----------------------------------------
windows-le2i:
	$(VENV) && $(PY) windows/make_windows.py \
	  --npz_dir $(NPZ_DIR_LE2I) \
	  --labels_json configs/labels/le2i.json \
	  --spans_json  configs/labels/le2i_spans.json \
	  --out_dir $(WIN_DIR_LE2I) \
	  --W $(WIN_W) --stride $(WIN_S) \
	  --fps_default $(FPS_LE2I) \
	  --train_list configs/splits/le2i_train.txt \
	  --val_list   configs/splits/le2i_val.txt \
	  --test_list  configs/splits/le2i_test.txt

windows-le2i-unlabeled:
	$(VENV) && $(PY) windows/make_unlabeled_windows.py \
	  --npz_dir $(NPZ_DIR_LE2I) \
	  --stems_txt configs/splits/le2i_test_unlabeled.txt \
	  --out_dir $(WIN_DIR_LE2I) \
	  --W $(WIN_W) --stride $(WIN_S) \
	  --fps_default $(FPS_LE2I)

windows-urfd:
	$(VENV) && $(PY) windows/make_windows.py \
	  --npz_dir $(NPZ_DIR_URFD) \
	  --labels_json configs/labels/urfd_auto.json \
	  --out_dir $(WIN_DIR_URFD) \
	  --W $(WIN_W) --stride $(WIN_S) \
	  --fps_default $(FPS_URFD) \
	  --train_list configs/splits/urfd_train.txt \
	  --val_list   configs/splits/urfd_val.txt \
	  --test_list  configs/splits/urfd_test.txt

windows-caucafall:
	$(VENV) && $(PY) windows/make_windows.py \
	  --npz_dir $(NPZ_DIR_CAUC) \
	  --labels_json configs/labels/caucafall_auto.json \
	  --out_dir $(WIN_DIR_CAUC) \
	  --W $(WIN_W) --stride $(WIN_S) \
	  --fps_default $(FPS_CAUC) \
	  --train_list configs/splits/caucafall_train.txt \
	  --val_list   configs/splits/caucafall_val.txt \
	  --test_list  configs/splits/caucafall_test.txt

windows-muvim:
	$(VENV) && $(PY) windows/make_windows.py \
	  --npz_dir $(NPZ_DIR_MUVIM) \
	  --labels_json configs/labels/muvim_auto.json \
	  --out_dir $(WIN_DIR_MUVIM) \
	  --W $(WIN_W) --stride $(WIN_S) \
	  --fps_default $(FPS_MUVIM) \
	  --train_list configs/splits/muvim_train.txt \
	  --val_list   configs/splits/muvim_val.txt \
	  --test_list  configs/splits/muvim_test.txt

# -----------------------------------------
# Checks
# -----------------------------------------
check-le2i:
	$(VENV) && $(PY) windows/check_windows.py --root $(WIN_DIR_LE2I)

check-urfd:
	$(VENV) && $(PY) windows/check_windows.py --root $(WIN_DIR_URFD)

check-caucafall:
	$(VENV) && $(PY) windows/check_windows.py --root $(WIN_DIR_CAUC)

check-muvim:
	$(VENV) && $(PY) windows/check_windows.py --root $(WIN_DIR_MUVIM)

# -----------------------------------------
# Train / Fit OPs / Eval / Plot
# -----------------------------------------

# ----------------------
# TCN training
# ----------------------
train-le2i:
	$(VENV) && $(PY) models/train_tcn.py \
	  --train_dir $(WIN_DIR_LE2I)/train \
	  --val_dir   $(WIN_DIR_LE2I)/val \
	  --epochs 50 --batch 128 --lr 1e-3 --seed $(SPLIT_SEED) \
	  --save_dir outputs/le2i_tcn_W$(WIN_W)S$(WIN_S)

train-urfd:
	$(VENV) && $(PY) models/train_tcn.py \
	  --train_dir $(WIN_DIR_URFD)/train \
	  --val_dir   $(WIN_DIR_URFD)/val \
	  --epochs 50 --batch 128 --lr 1e-3 --seed $(SPLIT_SEED) \
	  --save_dir outputs/urfd_tcn_W$(WIN_W)S$(WIN_S)

train-caucafall:
	$(VENV) && $(PY) models/train_tcn.py \
	  --train_dir $(WIN_DIR_CAUC)/train \
	  --val_dir   $(WIN_DIR_CAUC)/val \
	  --epochs 50 --batch 128 --lr 1e-3 --seed $(SPLIT_SEED) \
	  --save_dir outputs/caucafall_tcn_W$(WIN_W)S$(WIN_S)

train-muvim:
	$(VENV) && $(PY) models/train_tcn.py \
	  --train_dir $(WIN_DIR_MUVIM)/train \
	  --val_dir   $(WIN_DIR_MUVIM)/val \
	  --epochs 50 --batch 128 --lr 1e-3 --seed $(SPLIT_SEED) \
	  --save_dir outputs/muvim_tcn_W$(WIN_W)S$(WIN_S)

# ----------------------
# GCN training
# ----------------------
train-gcn-le2i:
	$(VENV) && $(PY) models/train_gcn.py \
	  --train_dir $(WIN_DIR_LE2I)/train \
	  --val_dir   $(WIN_DIR_LE2I)/val \
	  --epochs 50 --batch 128 --lr 1e-3 --seed $(SPLIT_SEED) \
	  --save_dir outputs/le2i_gcn_W$(WIN_W)S$(WIN_S)

train-gcn-urfd:
	$(VENV) && $(PY) models/train_gcn.py \
	  --train_dir $(WIN_DIR_URFD)/train \
	  --val_dir   $(WIN_DIR_URFD)/val \
	  --epochs 50 --batch 128 --lr 1e-3 --seed $(SPLIT_SEED) \
	  --save_dir outputs/urfd_gcn_W$(WIN_W)S$(WIN_S)

train-gcn-caucafall:
	$(VENV) && $(PY) models/train_gcn.py \
	  --train_dir $(WIN_DIR_CAUC)/train \
	  --val_dir   $(WIN_DIR_CAUC)/val \
	  --epochs 50 --batch 128 --lr 1e-3 --seed $(SPLIT_SEED) \
	  --save_dir outputs/caucafall_gcn_W$(WIN_W)S$(WIN_S)

train-gcn-muvim:
	$(VENV) && $(PY) models/train_gcn.py \
	  --train_dir $(WIN_DIR_MUVIM)/train \
	  --val_dir   $(WIN_DIR_MUVIM)/val \
	  --epochs 50 --batch 128 --lr 1e-3 --seed $(SPLIT_SEED) \
	  --save_dir outputs/muvim_gcn_W$(WIN_W)S$(WIN_S)

train-gcn-all: train-gcn-le2i train-gcn-urfd train-gcn-caucafall train-gcn-muvim
	@echo "GCN training complete for LE2I, URFD, CAUCAFall, MUVIM"

# ----------------------
# Fit OP thresholds (TCN)
# ----------------------
fit-ops-le2i:
	@mkdir -p configs
	$(VENV) && $(PY) eval/fit_ops.py \
	  --val_dir $(WIN_DIR_LE2I)/val \
	  --ckpt $(CKPT_LE2I) \
	  --out $(OPS_LE2I)

fit-ops-urfd:
	@mkdir -p configs
	$(VENV) && $(PY) eval/fit_ops.py \
	  --val_dir $(WIN_DIR_URFD)/val \
	  --ckpt $(CKPT_URFD) \
	  --out $(OPS_URFD)

fit-ops-caucafall:
	@mkdir -p configs
	$(VENV) && $(PY) eval/fit_ops.py \
	  --val_dir $(WIN_DIR_CAUC)/val \
	  --ckpt $(CKPT_CAUC) \
	  --out $(OPS_CAUC)

fit-ops-muvim:
	@mkdir -p configs
	$(VENV) && $(PY) eval/fit_ops.py \
	  --val_dir $(WIN_DIR_MUVIM)/val \
	  --ckpt $(CKPT_MUVIM) \
	  --out $(OPS_MUVIM)

# ----------------------
# Fit OP thresholds (GCN)
# NOTE: requires eval/fit_ops.py to support --arch gcn
# ----------------------
fit-ops-gcn-le2i:
	@mkdir -p configs
	$(VENV) && $(PY) eval/fit_ops.py \
	  --val_dir $(WIN_DIR_LE2I)/val \
	  --ckpt $(CKPT_LE2I_GCN) \
	  --arch gcn \
	  --out $(OPS_LE2I_GCN)

fit-ops-gcn-urfd:
	@mkdir -p configs
	$(VENV) && $(PY) eval/fit_ops.py \
	  --val_dir $(WIN_DIR_URFD)/val \
	  --ckpt $(CKPT_URFD_GCN) \
	  --arch gcn \
	  --out $(OPS_URFD_GCN)

